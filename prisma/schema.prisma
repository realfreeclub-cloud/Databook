// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  phone     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RepairRecord {
  id               String   @id @default(cuid())
  jobNumber        String   @unique
  name             String
  phone            String
  laptop           String
  password         String?
  issue            String
  extraProblem     String?
  chargerCollected Boolean  @default(false)
  work             String?
  amount           Float
  isPaid           Boolean  @default(false)
  date             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
